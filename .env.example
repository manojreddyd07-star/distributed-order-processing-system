# =================================================================
# ENVIRONMENT CONFIGURATION TEMPLATE
# =================================================================
# Copy this file to .env and update values for your environment
# DO NOT commit .env file to version control
# =================================================================

# =================================================================
# DATABASE CONFIGURATION
# =================================================================

# Order Service Database
ORDER_DB_HOST=postgres
ORDER_DB_PORT=5432
ORDER_DB_NAME=orderdb
ORDER_DB_USERNAME=postgres
ORDER_DB_PASSWORD=postgres  # CHANGE IN PRODUCTION

# Validation Service Database
VALIDATION_DB_HOST=postgres-validation
VALIDATION_DB_PORT=5432
VALIDATION_DB_NAME=validationdb
VALIDATION_DB_USERNAME=postgres
VALIDATION_DB_PASSWORD=postgres  # CHANGE IN PRODUCTION

# Payment Service Database
PAYMENT_DB_HOST=postgres-payment
PAYMENT_DB_PORT=5432
PAYMENT_DB_NAME=paymentdb
PAYMENT_DB_USERNAME=postgres
PAYMENT_DB_PASSWORD=postgres  # CHANGE IN PRODUCTION

# Inventory Service Database
INVENTORY_DB_HOST=postgres-inventory
INVENTORY_DB_PORT=5432
INVENTORY_DB_NAME=inventorydb
INVENTORY_DB_USERNAME=postgres
INVENTORY_DB_PASSWORD=postgres  # CHANGE IN PRODUCTION

# Fulfillment Service Database
FULFILLMENT_DB_HOST=postgres-fulfillment
FULFILLMENT_DB_PORT=5432
FULFILLMENT_DB_NAME=fulfillmentdb
FULFILLMENT_DB_USERNAME=postgres
FULFILLMENT_DB_PASSWORD=postgres  # CHANGE IN PRODUCTION

# Monitoring Service Database
MONITORING_DB_HOST=postgres-monitoring
MONITORING_DB_PORT=5432
MONITORING_DB_NAME=monitoringdb
MONITORING_DB_USERNAME=postgres
MONITORING_DB_PASSWORD=postgres  # CHANGE IN PRODUCTION

# =================================================================
# KAFKA CONFIGURATION
# =================================================================

KAFKA_BOOTSTRAP_SERVERS=kafka:29092
KAFKA_BROKER_ID=1
ZOOKEEPER_CLIENT_PORT=2181

# =================================================================
# SERVICE PORTS
# =================================================================

ORDER_SERVICE_PORT=8080
VALIDATION_SERVICE_PORT=8081
PAYMENT_SERVICE_PORT=8082
INVENTORY_SERVICE_PORT=8083
FULFILLMENT_SERVICE_PORT=8084
MONITORING_SERVICE_PORT=8086
FRONTEND_PORT=3000

# =================================================================
# SERVICE URLS (Internal Communication)
# =================================================================

ORDER_SERVICE_URL=http://order-service:8080
VALIDATION_SERVICE_URL=http://validation-service:8081
PAYMENT_SERVICE_URL=http://payment-service:8082
INVENTORY_SERVICE_URL=http://inventory-service:8083
FULFILLMENT_SERVICE_URL=http://fulfillment-service:8084
MONITORING_SERVICE_URL=http://monitoring-service:8086

# =================================================================
# FRONTEND CONFIGURATION
# =================================================================

# Backend API URL (for frontend)
REACT_APP_API_URL=http://localhost:8080

# =================================================================
# JVM CONFIGURATION (Optional Overrides)
# =================================================================

# Memory settings (percentage of container memory)
JAVA_MAX_RAM_PERCENTAGE=75.0
JAVA_INITIAL_RAM_PERCENTAGE=50.0

# GC Settings
JAVA_MAX_GC_PAUSE_MILLIS=200

# =================================================================
# SPRING BOOT PROFILES
# =================================================================

SPRING_PROFILES_ACTIVE=prod

# =================================================================
# LOGGING CONFIGURATION
# =================================================================

LOG_LEVEL_ROOT=INFO
LOG_LEVEL_APP=DEBUG

# =================================================================
# SECURITY (PRODUCTION ONLY)
# =================================================================

# JWT Secret (generate random secret in production)
# JWT_SECRET=changeme

# CORS Allowed Origins
# CORS_ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# =================================================================
# MONITORING & OBSERVABILITY (Optional)
# =================================================================

# Enable metrics
# MANAGEMENT_METRICS_ENABLED=true

# Enable health checks
# MANAGEMENT_HEALTH_ENABLED=true

# =================================================================
# DOCKER CONFIGURATION
# =================================================================

# Docker Compose project name
COMPOSE_PROJECT_NAME=order-processing

# =================================================================
# PRODUCTION NOTES
# =================================================================
# 
# Before deploying to production:
# 1. Change all database passwords
# 2. Generate secure JWT secret
# 3. Configure CORS for your domain
# 4. Set SPRING_PROFILES_ACTIVE=prod
# 5. Use secrets management (Docker secrets/Vault)
# 6. Enable SSL/TLS
# 7. Configure proper logging levels
# 8. Set up monitoring and alerting
# 9. Configure backup strategy
# 10. Review security settings
#
# =================================================================
